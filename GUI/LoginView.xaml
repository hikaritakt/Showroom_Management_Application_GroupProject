<Window x:Class="ShowroomApp.GUI.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Showroom Management - Login" Height="520" Width="450" WindowStartupLocation="CenterScreen"
        Background="#F5F7FA" FontFamily="Segoe UI">

    <!-- Styles for modern UI -->
    <Window.Resources>
        <!-- Modern TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#43A047"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#388E3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Layout -->
    <Grid>
        <!-- The Card Background containing the form -->
        <Border Background="White" Margin="40,30" Padding="30" CornerRadius="12" 
                VerticalAlignment="Center">
            
            <Border.Effect>
                <!-- Soft drop shadow imitating modern web cards -->
                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <TextBlock Text="WELCOME" FontSize="26" FontWeight="ExtraBold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Sign in to your Showroom account" FontSize="14" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Username -->
                <TextBlock Text="USERNAME" FontSize="12" Foreground="#666666" FontWeight="SemiBold" Margin="4,0,0,8"/>
                <TextBox x:Name="txtUsername" Margin="0,0,0,20"/>

                <!-- Password -->
                <TextBlock Text="PASSWORD" FontSize="12" Foreground="#666666" FontWeight="SemiBold" Margin="4,0,0,8"/>
                <PasswordBox x:Name="txtPassword" Margin="0,0,0,30"/>

                <!-- Login Button -->
                <Button Content="LOGIN" Click="BtnLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
