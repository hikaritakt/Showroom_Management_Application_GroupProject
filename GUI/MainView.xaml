<Window x:Class="ShowroomApp.GUI.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Showroom Management Application"
        Height="760"
        Width="1300"
        WindowStartupLocation="CenterScreen">
	<Grid Margin="12">
		<TabControl>
			<TabItem Header="Quản lý xe">
				<Grid Margin="10">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<WrapPanel Margin="0,0,0,10">
						<TextBox x:Name="txtCarName" Width="150" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtCarPrice" Width="120" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtCarQuantity" Width="90" Height="28" Margin="0,0,8,8"/>

						<ComboBox x:Name="cbBrand" Width="140" Height="28"
                                  DisplayMemberPath="BrandName" SelectedValuePath="BrandId"
                                  Margin="0,0,8,8"/>
						<ComboBox x:Name="cbModel" Width="140" Height="28"
                                  DisplayMemberPath="ModelName" SelectedValuePath="ModelId"
                                  Margin="0,0,8,8"/>
						<ComboBox x:Name="cbColor" Width="120" Height="28"
                                  DisplayMemberPath="ColorName" SelectedValuePath="ColorId"
                                  Margin="0,0,8,8"/>
						<ComboBox x:Name="cbStatus" Width="150" Height="28"
                                  DisplayMemberPath="StatusName" SelectedValuePath="StatusId"
                                  Margin="0,0,8,8"/>

						<Button Content="Thêm" Width="80" Margin="0,0,8,8" Click="AddCar_Click"/>
						<Button Content="Sửa" Width="80" Margin="0,0,8,8" Click="UpdateCar_Click"/>
						<Button Content="Xóa" Width="80" Margin="0,0,8,8" Click="DeleteCar_Click"/>
						<Button Content="Làm mới" Width="90" Margin="0,0,8,8" Click="RefreshAll_Click"/>
					</WrapPanel>

					<DataGrid x:Name="dgCars"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              IsReadOnly="True"
                              SelectionChanged="dgCars_SelectionChanged">
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding CarId}" Width="50"/>
							<DataGridTextColumn Header="Tên xe" Binding="{Binding CarName}" Width="180"/>
							<DataGridTextColumn Header="Hãng" Binding="{Binding BrandName}" Width="120"/>
							<DataGridTextColumn Header="Mẫu" Binding="{Binding ModelName}" Width="120"/>
							<DataGridTextColumn Header="Màu" Binding="{Binding ColorName}" Width="100"/>
							<DataGridTextColumn Header="Tình trạng" Binding="{Binding StatusName}" Width="130"/>
							<DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="120"/>
							<DataGridTextColumn Header="Tồn" Binding="{Binding Quantity}" Width="80"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>

			<TabItem Header="Quản lý kho xe">
				<Grid Margin="10">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<WrapPanel Margin="0,0,0,10">
						<ComboBox x:Name="cbInventoryCar" Width="220" Height="28"
                                  DisplayMemberPath="CarName" SelectedValuePath="CarId"
                                  Margin="0,0,8,8"/>
						<TextBox x:Name="txtInventoryQuantity" Width="100" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtInventoryPrice" Width="120" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtInventoryNote" Width="180" Height="28" Margin="0,0,8,8"/>
						<Button Content="Nhập xe" Width="100" Margin="0,0,8,8" Click="ImportCar_Click"/>
						<Button Content="Xuất xe" Width="100" Margin="0,0,8,8" Click="ExportCar_Click"/>
					</WrapPanel>

					<DataGrid x:Name="dgCarInventory" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding TransactionId}" Width="50"/>
							<DataGridTextColumn Header="Car ID" Binding="{Binding ItemId}" Width="70"/>
							<DataGridTextColumn Header="Tên xe" Binding="{Binding ItemName}" Width="180"/>
							<DataGridTextColumn Header="Loại" Binding="{Binding TransactionType}" Width="100"/>
							<DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="70"/>
							<DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="120"/>
							<DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="160"/>
							<DataGridTextColumn Header="Ngày" Binding="{Binding TransactionDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>

			<TabItem Header="Quản lý phụ kiện">
				<Grid Margin="10">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<WrapPanel Margin="0,0,0,10">
						<TextBox x:Name="txtAccessoryName" Width="150" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtAccessoryPrice" Width="120" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtAccessoryQuantity" Width="90" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtAccessoryDescription" Width="180" Height="28" Margin="0,0,8,8"/>
						<Button Content="Thêm" Width="80" Margin="0,0,8,8" Click="AddAccessory_Click"/>
						<Button Content="Sửa" Width="80" Margin="0,0,8,8" Click="UpdateAccessory_Click"/>
						<Button Content="Xóa" Width="80" Margin="0,0,8,8" Click="DeleteAccessory_Click"/>
					</WrapPanel>

					<DataGrid x:Name="dgAccessories"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="dgAccessories_SelectionChanged"
                              Margin="0,0,0,10">
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding AccessoryId}" Width="50"/>
							<DataGridTextColumn Header="Tên phụ kiện" Binding="{Binding AccessoryName}" Width="180"/>
							<DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="120"/>
							<DataGridTextColumn Header="Tồn" Binding="{Binding Quantity}" Width="70"/>
							<DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="220"/>
						</DataGrid.Columns>
					</DataGrid>

					<WrapPanel Grid.Row="2" Margin="0,0,0,10">
						<ComboBox x:Name="cbAccessoryInventory" Width="220" Height="28"
                                  DisplayMemberPath="AccessoryName" SelectedValuePath="AccessoryId"
                                  Margin="0,0,8,8"/>
						<TextBox x:Name="txtAccessoryInventoryQuantity" Width="100" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtAccessoryInventoryPrice" Width="120" Height="28" Margin="0,0,8,8"/>
						<TextBox x:Name="txtAccessoryInventoryNote" Width="180" Height="28" Margin="0,0,8,8"/>
						<Button Content="Nhập phụ kiện" Width="120" Margin="0,0,8,8" Click="ImportAccessory_Click"/>
						<Button Content="Xuất phụ kiện" Width="120" Margin="0,0,8,8" Click="ExportAccessory_Click"/>
					</WrapPanel>

					<DataGrid x:Name="dgAccessoryInventory" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True">
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding TransactionId}" Width="50"/>
							<DataGridTextColumn Header="PK ID" Binding="{Binding ItemId}" Width="70"/>
							<DataGridTextColumn Header="Tên phụ kiện" Binding="{Binding ItemName}" Width="180"/>
							<DataGridTextColumn Header="Loại" Binding="{Binding TransactionType}" Width="100"/>
							<DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="70"/>
							<DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="120"/>
							<DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="160"/>
							<DataGridTextColumn Header="Ngày" Binding="{Binding TransactionDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Window>